{
	"info": {
		"_postman_id": "dhir-dhir-api-test",
		"name": "Dhir Dhir Music Academy API",
		"description": "Collection to test Raag, Scale and Tempo endpoints for the Dhir Dhir Music Academy app.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Fetch Raag Yaman",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "http://localhost:5000/raag/yaman",
					"protocol": "http",
					"host": ["localhost"],
					"port": "5000",
					"path": ["raag", "yaman"]
				},
				"description": "Returns the lehra pattern and notes for Raag Yaman."
			},
			"response": []
		},
		{
			"name": "2. Map Scale (Example C)",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "http://localhost:5000/map-scale?scale=C",
					"protocol": "http",
					"host": ["localhost"],
					"port": "5000",
					"path": ["map-scale"],
					"query": [
						{
							"key": "scale",
							"value": "C"
						}
					]
				},
				"description": "Maps Indian notes (Sa, Re, Ga...) to Western notes for a specific root scale."
			},
			"response": []
		},
		{
			"name": "3. Map Scale (Example D#)",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "http://localhost:5000/map-scale?scale=D%23",
					"protocol": "http",
					"host": ["localhost"],
					"port": "5000",
					"path": ["map-scale"],
					"query": [
						{
							"key": "scale",
							"value": "D#"
						}
					]
				}
			},
			"response": []
		},
		{
			"name": "4. Calculate Tempo (60 BPM)",
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"bpm\": 60,\n  \"notes\": [\n    { \"note\": \"Sa\", \"duration\": 1 },\n    { \"note\": \"Re\", \"duration\": 1 },\n    { \"note\": \"Ga\", \"duration\": 2 }\n  ]\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "http://localhost:5000/tempo/calculate",
					"protocol": "http",
					"host": ["localhost"],
					"port": "5000",
					"path": ["tempo", "calculate"]
				},
				"description": "Calculates millisecond durations for each note based on the provided BPM."
			},
			"response": []
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [""]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [""]
			}
		}
	]
}
